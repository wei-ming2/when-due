{
  "name": "when-due",
  "version": "0.1.0",
  "private": true,
  "description": "A focused desktop deadline tracker with a clear sense of when things are due",
  "repository": {
    "type": "git",
    "url": "https://github.com/wei-ming2/when-due.git"
  },
  "author": {
    "name": "Weiming"
  },
  "homepage": "https://github.com/wei-ming2/when-due",
  "bugs": {
    "url": "https://github.com/wei-ming2/when-due/issues"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:windows:mac": "env PATH=\"/opt/homebrew/opt/llvm/bin:$PATH\" XWIN_CACHE_DIR=\"$PWD/.xwin-cache\" tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "lint": "eslint src --ext .ts,.svelte",
    "format": "prettier --write .",
    "type-check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^2.0.3",
    "@sveltejs/kit": "^1.27.0",
    "@sveltejs/vite-plugin-svelte": "^2.4.6",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "svelte": "^4.2.0",
    "svelte-check": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "uuid": "^9.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
